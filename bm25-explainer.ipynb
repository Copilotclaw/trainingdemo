    "---\n",
    "\n",
    "## 3. A Product Catalog Demo\n",
    "\n",
    "Let's build a small product catalog — similar to what was used in the real-world experiment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# A sample product catalog: 20 products across categories\n",
    "products = [\n",
    "    {\"id\": \"W001\", \"name\": \"Merlot Reserve 2021\", \"brand\": \"Château Bordeaux\", \"category\": \"Wine\", \"description\": \"Full-bodied red wine with plum and cherry notes, aged 18 months in oak barrels\"},\n",
    "    {\"id\": \"W002\", \"name\": \"Pinot Noir Classic\", \"brand\": \"Oregon Valley\", \"category\": \"Wine\", \"description\": \"Light red wine with earthy notes, pairs well with salmon and mushrooms\"},\n",
    "    {\"id\": \"W003\", \"name\": \"Cabernet Sauvignon Bold\", \"brand\": \"Napa Ridge\", \"category\": \"Wine\", \"description\": \"Robust red wine with blackcurrant and tobacco, full tannins\"},\n",
    "    {\"id\": \"W004\", \"name\": \"Sparkling Prosecco Brut\", \"brand\": \"Venezia\", \"category\": \"Wine\", \"description\": \"Light and refreshing sparkling wine, perfect for celebrations and hot summer days\"},\n",
    "    {\"id\": \"W005\", \"name\": \"Riesling Citrus Dry\", \"brand\": \"Rhine Valley\", \"category\": \"Wine\", \"description\": \"Crisp and refreshing white wine with citrus aromas, pairs with seafood\"},\n",
    "    {\"id\": \"C001\", \"name\": \"Stainless Steel Pan 28cm\", \"brand\": \"CookMaster\", \"category\": \"Cookware\", \"description\": \"Professional stainless steel frying pan, induction compatible, dishwasher safe\"},\n",
    "    {\"id\": \"C002\", \"name\": \"Cast Iron Skillet 26cm\", \"brand\": \"Lodge\", \"category\": \"Cookware\", \"description\": \"Pre-seasoned cast iron skillet, retains heat evenly, ideal for searing and baking\"},\n",
    "    {\"id\": \"C003\", \"name\": \"Cookware Gift Set 5-piece\", \"brand\": \"CookMaster\", \"category\": \"Cookware\", \"description\": \"Complete cooking gift set with pots, pans and lids, perfect gift for cooking enthusiasts and home chefs\"},\n",
    "    {\"id\": \"C004\", \"name\": \"Non-stick Wok 32cm\", \"brand\": \"TitanCook\", \"category\": \"Cookware\", \"description\": \"Large non-stick wok for stir-fry cooking, ergonomic handle, suitable for all hobs\"},\n",
    "    {\"id\": \"E001\", \"name\": \"Espresso Machine X-500\", \"brand\": \"BrewTech\", \"category\": \"Coffee\", \"description\": \"Professional 15-bar espresso machine with steam wand, model X-500, stainless steel housing\"},\n",
    "    {\"id\": \"E002\", \"name\": \"Coffee Grinder CG-200\", \"brand\": \"BrewTech\", \"category\": \"Coffee\", \"description\": \"Burr coffee grinder, 40 grind settings, model CG-200, suitable for espresso and filter coffee\"},\n",
    "    {\"id\": \"E003\", \"name\": \"Capsule Machine K-Slim\", \"brand\": \"KafeMax\", \"category\": \"Coffee\", \"description\": \"Compact capsule coffee machine, 19-bar pump, makes espresso and lungo, model K-Slim\"},\n",
    "    {\"id\": \"B001\", \"name\": \"Sparkling Water SodaMax\", \"brand\": \"FizzCo\", \"category\": \"Beverages\", \"description\": \"Sparkling water maker, carbonates still water in seconds, refreshing and eco-friendly\"},\n",
    "    {\"id\": \"B002\", \"name\": \"Cold Brew Coffee Kit\", \"brand\": \"BrewTech\", \"category\": \"Beverages\", \"description\": \"Complete cold brew coffee kit, 1L capacity, perfect for refreshing summer coffee drinks\"},\n",
    "    {\"id\": \"B003\", \"name\": \"Citrus Juicer Electric\", \"brand\": \"FreshPress\", \"category\": \"Beverages\", \"description\": \"Electric citrus juicer for fresh orange, lemon and grapefruit juice, refreshing and vitamin-rich\"},\n",
    "    {\"id\": \"K001\", \"name\": \"Chef Knife 20cm\", \"brand\": \"Wüsthof\", \"category\": \"Knives\", \"description\": \"Professional chef knife with German stainless steel blade, balanced weight, gift box included\"},\n",
    "    {\"id\": \"K002\", \"name\": \"Knife Set 6-piece\", \"brand\": \"Wüsthof\", \"category\": \"Knives\", \"description\": \"Complete knife set with chef knife, bread knife and paring knives, perfect gift for cooking lovers\"},\n",
    "    {\"id\": \"T001\", \"name\": \"Digital Thermometer Pro\", \"brand\": \"ThermoChef\", \"category\": \"Tools\", \"description\": \"Instant-read digital meat thermometer, waterproof, model T-Pro, 3-second reading\"},\n",
    "    {\"id\": \"T002\", \"name\": \"Kitchen Scale KS-1000\", \"brand\": \"PrecisionCo\", \"category\": \"Tools\", \"description\": \"Digital kitchen scale, 1g precision, tare function, model KS-1000, stainless steel platform\"},\n",
    "    {\"id\": \"T003\", \"name\": \"Mandoline Slicer X-300\", \"brand\": \"SliceMaster\", \"category\": \"Tools\", \"description\": \"Adjustable mandoline food slicer, 5 thickness settings, model X-300, safety guard included\"},\n",
    "]\n",
    "\n",
    "# For BM25, combine fields with weights: name (3x), brand (2x), category (2x), description (1x)\n",
    "def build_weighted_doc(p):\n",
    "    return \" \".join([\n",
    "        p[\"name\"] * 3,        # name 3x weight\n",
    "        p[\"brand\"] * 2,       # brand 2x weight  \n",
    "        p[\"category\"] * 2,    # category 2x weight\n",
    "        p[\"description\"]      # description 1x weight\n",
    "    ])\n",
    "\n",
    "docs = [build_weighted_doc(p) for p in products]\n",
    "bm25 = BM25(docs)\n",
    "\n",
    "print(f\"✅ Indexed {len(products)} products\")\n",
